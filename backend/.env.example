# activia-trace backend - Environment variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://activia:changeme@localhost:5432/activia_trace

# JWT signing key - minimum 32 characters, keep secret
SECRET_KEY=change-me-to-a-random-secret-key-of-at-least-32-chars

# AES-256 encryption key - exactly 32 characters, keep secret
ENCRYPTION_KEY=change-me-32-char-encryption-key!

# Access token TTL in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Test database (used by pytest, separate from dev/prod)
DATABASE_URL_TEST=postgresql+asyncpg://activia:changeme@localhost:5432/activia_trace_test

# Observability (optional - app starts without these)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=activia-trace-api
# OTEL_ENABLED=true
